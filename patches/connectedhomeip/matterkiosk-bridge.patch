+
+void WriteMatterKioskMessage(const Json::Value & value)
+{
+    if (sChipNamedPipeCommands.OutPath().empty())
+    {
+        return;
+    }
+
+    sChipNamedPipeCommands.WriteToOutPipe(MatterKioskJsonString(value));
+}
+
+uint64_t MatterKioskHashTargetId(const std::string & targetId)
+{
+    constexpr uint64_t kFnvOffsetBasis = 1469598103934665603ULL;
+    constexpr uint64_t kFnvPrime       = 1099511628211ULL;
+
+    uint64_t hash = kFnvOffsetBasis;
+    for (char ch : targetId)
+    {
+        hash ^= static_cast<uint64_t>(static_cast<unsigned char>(ch));
+        hash *= kFnvPrime;
+    }
+    return hash;
+}
+
+std::string MatterKioskUniqueIdForTarget(const std::string & targetId)
+{
+    char buffer[Device::kDeviceUniqueIdSize + 1] = { 0 };
+    snprintf(buffer, sizeof(buffer), "MK-%016llx", static_cast<unsigned long long>(MatterKioskHashTargetId(targetId)));
+    return std::string(buffer);
+}
+
+MatterKioskBridgeDevice * FindMatterKioskDeviceByTargetId(const std::string & targetId)
+{
+    auto it = gMatterKioskDevicesByTargetId.find(targetId);
+    return it == gMatterKioskDevicesByTargetId.end() ? nullptr : it->second;
+}
+
+MatterKioskBridgeDevice * FindMatterKioskDeviceByBridge(DeviceOnOff * dev)
+{
+    auto it = gMatterKioskDevicesByDevice.find(dev);
+    return it == gMatterKioskDevicesByDevice.end() ? nullptr : it->second;
+}
+
+Json::Value BuildMatterKioskStatusResult()
+{
+    Json::Value result(Json::objectValue);
+    result["started"] = true;
+    result["paired"]  = Server::GetInstance().GetFabricTable().FabricCount() > 0;
+
+    char qrCodeBuffer[256]        = { 0 };
+    chip::MutableCharSpan qrCode  = chip::MutableCharSpan(qrCodeBuffer, sizeof(qrCodeBuffer));
+    if (GetQRCode(qrCode, LinuxDeviceOptions::GetInstance().payload) == CHIP_NO_ERROR)
+    {
+        result["qrCode"] = std::string(qrCode.data(), qrCode.size());
+    }
+    else
+    {
+        result["qrCode"] = "";
+    }
+
+    char manualBuffer[64]                    = { 0 };
+    chip::MutableCharSpan manualPairingCode  = chip::MutableCharSpan(manualBuffer, sizeof(manualBuffer));
+    if (GetManualPairingCode(manualPairingCode, LinuxDeviceOptions::GetInstance().payload) == CHIP_NO_ERROR)
+    {
+        result["manualPairingCode"] = std::string(manualPairingCode.data(), manualPairingCode.size());
+    }
+    else
+    {
+        result["manualPairingCode"] = "";
+    }
+
+    return result;
+}
+
+MatterKioskBridgeDevice * EnsureMatterKioskDevice(const std::string & targetId, const std::string & targetName)
+{
+    if (auto * existing = FindMatterKioskDeviceByTargetId(targetId))
+    {
+        existing->device->SetName(targetName.c_str());
+        return existing;
+    }
+
+    auto entry      = std::make_unique<MatterKioskBridgeDevice>();
+    entry->targetId = targetId;
+    entry->device   = std::make_unique<DeviceOnOff>(targetName.c_str(), "MatterKiosk");
+    entry->device->SetChangeCallback(&HandleDeviceOnOffStatusChanged);
+
+    const std::string uniqueId = MatterKioskUniqueIdForTarget(targetId);
+    entry->device->SetUniqueId(uniqueId.c_str());
+
+#if !CHIP_CONFIG_USE_ENDPOINT_UNIQUE_ID
+    int index = AddDeviceEndpoint(entry->device.get(), &bridgedLightEndpoint, Span<const EmberAfDeviceType>(gBridgedOnOffDeviceTypes),
+                                  Span<DataVersion>(entry->dataVersions), 1);
+#else
+    int index = AddDeviceEndpoint(entry->device.get(), &bridgedLightEndpoint, Span<const EmberAfDeviceType>(gBridgedOnOffDeviceTypes),
+                                  Span<DataVersion>(entry->dataVersions), chip::CharSpan::fromCharString(uniqueId.c_str()), 1);
+#endif
+
+    VerifyOrReturnValue(index >= 0, nullptr);
+
+    MatterKioskBridgeDevice * raw = entry.get();
+    gMatterKioskDevicesByTargetId.emplace(targetId, raw);
+    gMatterKioskDevicesByDevice.emplace(raw->device.get(), raw);
+    gMatterKioskDevices.push_back(std::move(entry));
+    return raw;
+}
+
+void RemoveMatterKioskDevice(const std::string & targetId)
+{
+    MatterKioskBridgeDevice * existing = FindMatterKioskDeviceByTargetId(targetId);
+    VerifyOrReturn(existing != nullptr);
+
+    gMatterKioskDevicesByDevice.erase(existing->device.get());
+    gMatterKioskDevicesByTargetId.erase(targetId);
+    RemoveDeviceEndpoint(existing->device.get());
+
+    auto newEnd = std::remove_if(gMatterKioskDevices.begin(), gMatterKioskDevices.end(),
+                                 [&](const std::unique_ptr<MatterKioskBridgeDevice> & entry) {
+                                     return entry.get() == existing;
+                                 });
+    gMatterKioskDevices.erase(newEnd, gMatterKioskDevices.end());
+}
+
+void SyncMatterKioskTargets(const Json::Value & targets)
+{
+    std::unordered_map<std::string, std::string> desiredTargets;
+
+    if (targets.isArray())
+    {
+        for (const auto & entry : targets)
+        {
+            if (!entry.isObject())
+            {
+                continue;
+            }
+
+            if (!entry.isMember("id") || !entry["id"].isString())
+            {
+                continue;
+            }
+
+            const bool enabled = !entry.isMember("enabled") || entry["enabled"].asBool();
+            const std::string targetId = entry["id"].asString();
+            if (!enabled)
+            {
+                continue;
+            }
+
+            const std::string targetName = entry.isMember("name") && entry["name"].isString() ? entry["name"].asString() : targetId;
+            desiredTargets[targetId]     = targetName;
+            VerifyOrDie(EnsureMatterKioskDevice(targetId, targetName) != nullptr);
+        }
+    }
+
+    std::vector<std::string> targetIdsToRemove;
+    for (const auto & existing : gMatterKioskDevices)
+    {
+        if (desiredTargets.find(existing->targetId) == desiredTargets.end())
+        {
+            targetIdsToRemove.push_back(existing->targetId);
+        }
+    }
+
+    for (const auto & targetId : targetIdsToRemove)
+    {
+        RemoveMatterKioskDevice(targetId);
+    }
+}
+
+bool SetMatterKioskTargetOff(const std::string & targetId)
+{
+    MatterKioskBridgeDevice * existing = FindMatterKioskDeviceByTargetId(targetId);
+    VerifyOrReturnValue(existing != nullptr, false);
+    existing->device->SetOnOff(false);
+    return true;
+}
+
+void WriteMatterKioskResponse(int requestId, bool ok, const Json::Value * result, const std::string & error)
+{
+    Json::Value response(Json::objectValue);
+    response["type"] = "response";
+    if (requestId >= 0)
+    {
+        response["requestId"] = requestId;
+    }
+    response["ok"] = ok;
+    if (result != nullptr)
+    {
+        response["result"] = *result;
+    }
+    if (!ok)
+    {
+        response["error"] = error;
+    }
+    WriteMatterKioskMessage(response);
+}
+
+void EmitMatterKioskOnOffEvent(DeviceOnOff * dev)
+{
+    VerifyOrReturn(gMatterKioskMode);
+
+    MatterKioskBridgeDevice * entry = FindMatterKioskDeviceByBridge(dev);
+    VerifyOrReturn(entry != nullptr);
+
+    Json::Value event(Json::objectValue);
+    event["type"]     = dev->IsOn() ? "target-triggered" : "target-turned-off";
+    event["targetId"] = entry->targetId;
+    WriteMatterKioskMessage(event);
+}
