+MatterKioskBridgeDevice * EnsureMatterKioskDevice(const std::string & targetId, const std::string & targetName, bool dimmable)
+{
+    if (auto * existing = FindMatterKioskDeviceByTargetId(targetId))
+    {
+        existing->device->SetName(targetName.c_str());
+        existing->dimmable = dimmable;
+        return existing;
+    }
+
+    auto entry      = std::make_unique<MatterKioskBridgeDevice>();
+    entry->targetId = targetId;
+    entry->device   = std::make_unique<DeviceOnOff>(targetName.c_str(), "MatterKiosk");
+    entry->dimmable = dimmable;
+    entry->device->SetChangeCallback(&HandleDeviceOnOffStatusChanged);
+
+    const std::string uniqueId = MatterKioskUniqueIdForTarget(targetId);
+    entry->device->SetUniqueId(uniqueId.c_str());
+
+#if !CHIP_CONFIG_USE_ENDPOINT_UNIQUE_ID
+    int index = dimmable
+        ? AddDeviceEndpoint(entry->device.get(), &bridgedDimmableLightEndpoint,
+                            Span<const EmberAfDeviceType>(gBridgedDimmableLightDeviceTypes),
+                            Span<DataVersion>(entry->dataVersions.data(), MATTER_ARRAY_SIZE(bridgedDimmableLightClusters)), 1)
+        : AddDeviceEndpoint(entry->device.get(), &bridgedLightEndpoint, Span<const EmberAfDeviceType>(gBridgedOnOffDeviceTypes),
+                            Span<DataVersion>(entry->dataVersions.data(), MATTER_ARRAY_SIZE(bridgedLightClusters)), 1);
+#else
+    int index = dimmable
+        ? AddDeviceEndpoint(entry->device.get(), &bridgedDimmableLightEndpoint,
+                            Span<const EmberAfDeviceType>(gBridgedDimmableLightDeviceTypes),
+                            Span<DataVersion>(entry->dataVersions.data(), MATTER_ARRAY_SIZE(bridgedDimmableLightClusters)),
+                            chip::CharSpan::fromCharString(uniqueId.c_str()), 1)
+        : AddDeviceEndpoint(entry->device.get(), &bridgedLightEndpoint, Span<const EmberAfDeviceType>(gBridgedOnOffDeviceTypes),
+                            Span<DataVersion>(entry->dataVersions.data(), MATTER_ARRAY_SIZE(bridgedLightClusters)),
+                            chip::CharSpan::fromCharString(uniqueId.c_str()), 1);
+#endif
+
+    VerifyOrReturnValue(index >= 0, nullptr);
+
+    MatterKioskBridgeDevice * raw = entry.get();
+    gMatterKioskDevicesByTargetId.emplace(targetId, raw);
+    gMatterKioskDevicesByDevice.emplace(raw->device.get(), raw);
+    gMatterKioskDevices.push_back(std::move(entry));
+    return raw;
+}
+
+void RemoveMatterKioskDevice(const std::string & targetId)
+{
+    MatterKioskBridgeDevice * existing = FindMatterKioskDeviceByTargetId(targetId);
+    VerifyOrReturn(existing != nullptr);
+
+    gMatterKioskDevicesByDevice.erase(existing->device.get());
+    gMatterKioskDevicesByTargetId.erase(targetId);
+    RemoveDeviceEndpoint(existing->device.get());
+
+    auto newEnd = std::remove_if(gMatterKioskDevices.begin(), gMatterKioskDevices.end(),
+                                 [&](const std::unique_ptr<MatterKioskBridgeDevice> & entry) {
+                                     return entry.get() == existing;
+                                 });
+    gMatterKioskDevices.erase(newEnd, gMatterKioskDevices.end());
+}
+
+void SyncMatterKioskTargets(const Json::Value & targets)
+{
+    struct DesiredTarget
+    {
+        std::string name;
+        bool dimmable = false;
+        bool on = false;
+        uint8_t level = 254;
+    };
+
+    std::unordered_map<std::string, DesiredTarget> desiredTargets;
+    gMatterKioskSuppressEvents = true;
+
+    if (targets.isArray())
+    {
+        for (const auto & entry : targets)
+        {
+            if (!entry.isObject())
+            {
+                continue;
+            }
+
+            if (!entry.isMember("id") || !entry["id"].isString())
+            {
+                continue;
+            }
+
+            const bool enabled = !entry.isMember("enabled") || entry["enabled"].asBool();
+            const std::string targetId = entry["id"].asString();
+            if (!enabled)
+            {
+                continue;
+            }
+
+            const std::string targetName = entry.isMember("name") && entry["name"].isString() ? entry["name"].asString() : targetId;
+            const std::string deviceType = entry.isMember("deviceType") && entry["deviceType"].isString()
+                ? entry["deviceType"].asString()
+                : "on-off-plug-in-unit";
+            const bool dimmable = deviceType == "dimmable-light";
+            const bool on = entry.isMember("on") && entry["on"].isBool() ? entry["on"].asBool() : false;
+            const uint8_t level = entry.isMember("level") && entry["level"].isInt() ? ClampMatterKioskLevel(entry["level"].asInt()) : 254;
+
+            desiredTargets[targetId] = DesiredTarget{
+                .name = targetName,
+                .dimmable = dimmable,
+                .on = on,
+                .level = level,
+            };
+        }
+    }
+
+    std::vector<std::string> targetIdsToRemove;
+    for (const auto & existing : gMatterKioskDevices)
+    {
+        const auto it = desiredTargets.find(existing->targetId);
+        if (it == desiredTargets.end() || it->second.dimmable != existing->dimmable)
+        {
+            targetIdsToRemove.push_back(existing->targetId);
+        }
+    }
+
+    for (const auto & targetId : targetIdsToRemove)
+    {
+        RemoveMatterKioskDevice(targetId);
+    }
+
+    for (const auto & [targetId, target] : desiredTargets)
+    {
+        MatterKioskBridgeDevice * device = EnsureMatterKioskDevice(targetId, target.name, target.dimmable);
+        VerifyOrDie(device != nullptr);
+
+        if (target.dimmable)
+        {
+            SetMatterKioskLevel(device, target.level, false);
+        }
+        device->device->SetOnOff(target.on);
+    }
+
+    gMatterKioskSuppressEvents = false;
+}
+
+bool SetMatterKioskTargetOff(const std::string & targetId)
+{
+    Json::Value target(Json::objectValue);
+    target["id"] = targetId;
+    target["on"] = false;
+    return SetMatterKioskTargetState(target);
+}
+
+bool SetMatterKioskTargetState(const Json::Value & target)
+{
+    VerifyOrReturnValue(target.isObject(), false);
+
+    const std::string targetId = target.get("id", "").asString();
+    VerifyOrReturnValue(!targetId.empty(), false);
+
+    MatterKioskBridgeDevice * existing = FindMatterKioskDeviceByTargetId(targetId);
+    VerifyOrReturnValue(existing != nullptr, false);
+
+    const bool previousSuppressState = gMatterKioskSuppressEvents;
+    gMatterKioskSuppressEvents = true;
+
+    if (existing->dimmable && target.isMember("level") && target["level"].isInt())
+    {
+        SetMatterKioskLevel(existing, ClampMatterKioskLevel(target["level"].asInt()), false);
+    }
+
+    if (target.isMember("on") && target["on"].isBool())
+    {
+        existing->device->SetOnOff(target["on"].asBool());
+    }
+
+    gMatterKioskSuppressEvents = previousSuppressState;
+    return true;
+}
+
+void WriteMatterKioskResponse(int requestId, bool ok, const Json::Value * result, const std::string & error)
+{
+    Json::Value response(Json::objectValue);
+    response["type"] = "response";
+    if (requestId >= 0)
+    {
+        response["requestId"] = requestId;
+    }
+    response["ok"] = ok;
+    if (result != nullptr)
+    {
+        response["result"] = *result;
+    }
+    if (!ok)
+    {
+        response["error"] = error;
+    }
+    WriteMatterKioskMessage(response);
+}
+
+void EmitMatterKioskOnOffEvent(DeviceOnOff * dev)
+{
+    VerifyOrReturn(gMatterKioskMode && !gMatterKioskSuppressEvents);
+
+    MatterKioskBridgeDevice * entry = FindMatterKioskDeviceByBridge(dev);
+    VerifyOrReturn(entry != nullptr);
+
+    Json::Value event(Json::objectValue);
+    event["type"]     = dev->IsOn() ? "target-triggered" : "target-turned-off";
+    event["targetId"] = entry->targetId;
+    WriteMatterKioskMessage(event);
+}
+
+void EmitMatterKioskLevelEvent(DeviceOnOff * dev)
+{
+    VerifyOrReturn(gMatterKioskMode && !gMatterKioskSuppressEvents);
+
+    MatterKioskBridgeDevice * entry = FindMatterKioskDeviceByBridge(dev);
+    VerifyOrReturn(entry != nullptr && entry->dimmable);
+
+    Json::Value event(Json::objectValue);
+    event["type"]     = "target-level-changed";
+    event["targetId"] = entry->targetId;
+    event["level"]    = entry->level;
+    WriteMatterKioskMessage(event);
+}
