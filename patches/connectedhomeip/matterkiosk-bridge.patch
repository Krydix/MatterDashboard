+Protocols::InteractionModel::Status HandleReadLevelControlAttribute(MatterKioskBridgeDevice * entry, chip::AttributeId attributeId,
+                                                                    uint8_t * buffer, uint16_t maxReadLength)
+{
+    using namespace LevelControl::Attributes;
+
+    VerifyOrReturnValue(entry != nullptr && entry->dimmable, Protocols::InteractionModel::Status::Failure);
+
+    if ((attributeId == CurrentLevel::Id) && (maxReadLength == 1))
+    {
+        *buffer = entry->level;
+    }
+    else if ((attributeId == RemainingTime::Id) && (maxReadLength == 2))
+    {
+        uint16_t remainingTime = 0;
+        memcpy(buffer, &remainingTime, sizeof(remainingTime));
+    }
+    else if ((attributeId == MinLevel::Id) && (maxReadLength == 1))
+    {
+        *buffer = 1;
+    }
+    else if ((attributeId == MaxLevel::Id) && (maxReadLength == 1))
+    {
+        *buffer = 254;
+    }
+    else if ((attributeId == Options::Id) && (maxReadLength == 1))
+    {
+        *buffer = 0;
+    }
+    else if ((attributeId == OnOffTransitionTime::Id) && (maxReadLength == 2))
+    {
+        uint16_t transitionTime = 0;
+        memcpy(buffer, &transitionTime, sizeof(transitionTime));
+    }
+    else if ((attributeId == FeatureMap::Id) && (maxReadLength == 4))
+    {
+        uint32_t featureMap = kMatterKioskLevelControlFeatureMap;
+        memcpy(buffer, &featureMap, sizeof(featureMap));
+    }
+    else if ((attributeId == ClusterRevision::Id) && (maxReadLength == 2))
+    {
+        uint16_t revision = kMatterKioskLevelControlClusterRevision;
+        memcpy(buffer, &revision, sizeof(revision));
+    }
+    else
+    {
+        return Protocols::InteractionModel::Status::Failure;
+    }
+
+    return Protocols::InteractionModel::Status::Success;
+}
+
+Protocols::InteractionModel::Status HandleWriteLevelControlAttribute(MatterKioskBridgeDevice * entry, chip::AttributeId attributeId,
+                                                                     uint8_t * buffer)
+{
+    VerifyOrReturnValue(entry != nullptr && entry->dimmable, Protocols::InteractionModel::Status::Failure);
+
+    if (attributeId != LevelControl::Attributes::CurrentLevel::Id)
+    {
+        return Protocols::InteractionModel::Status::Failure;
+    }
+
+    SetMatterKioskLevel(entry, *buffer, true);
+    return Protocols::InteractionModel::Status::Success;
+}
