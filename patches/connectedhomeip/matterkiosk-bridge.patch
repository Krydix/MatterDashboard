+class MatterKioskLevelControlCommandHandler : public CommandHandlerInterface
+{
+public:
+    MatterKioskLevelControlCommandHandler() : CommandHandlerInterface(Optional<EndpointId>::Missing(), LevelControl::Id) {}
+
+    void InvokeCommand(HandlerContext & handlerContext) override;
+};
+
+MatterKioskLevelControlCommandHandler gMatterKioskLevelControlCommandHandler;
+
+constexpr uint32_t kMatterKioskLevelControlFeatureMap = 0x00000003;
+constexpr uint16_t kMatterKioskLevelControlClusterRevision = 0x0007;
+
+[[nodiscard]] uint8_t ClampMatterKioskLevel(int value)
+{
+    return static_cast<uint8_t>(std::clamp(value, 1, 254));
+}
+
+void SetMatterKioskLevel(MatterKioskBridgeDevice * entry, uint8_t level, bool emitEvent)
+{
+    VerifyOrReturn(entry != nullptr && entry->dimmable);
+    level = ClampMatterKioskLevel(level);
+
+    if (entry->level == level)
+    {
+        return;
+    }
+
+    entry->level = level;
+    ScheduleReportingCallback(entry->device.get(), LevelControl::Id, LevelControl::Attributes::CurrentLevel::Id);
+    if (emitEvent)
+    {
+        EmitMatterKioskLevelEvent(entry->device.get());
+    }
+}
+
+MatterKioskBridgeDevice * FindMatterKioskDeviceByEndpointId(EndpointId endpointId)
+{
+    for (const auto & entry : gMatterKioskDevices)
+    {
+        if (entry->device != nullptr && entry->device->GetEndpointId() == endpointId)
+        {
+            return entry.get();
+        }
+    }
+
+    return nullptr;
+}
+
+void ApplyMatterKioskCommandLevel(CommandHandlerInterface::HandlerContext & handlerContext, MatterKioskBridgeDevice * entry,
+                                  uint8_t level, bool withOnOff)
+{
+    VerifyOrReturn(entry != nullptr && entry->dimmable);
+
+    level = ClampMatterKioskLevel(level);
+    if (withOnOff && !entry->device->IsOn())
+    {
+        entry->device->SetOnOff(true);
+    }
+
+    SetMatterKioskLevel(entry, level, true);
+    handlerContext.mCommandHandler.AddStatus(handlerContext.mRequestPath, Protocols::InteractionModel::Status::Success);
+}
+
+void ApplyMatterKioskStep(CommandHandlerInterface::HandlerContext & handlerContext, MatterKioskBridgeDevice * entry,
+                          LevelControl::StepModeEnum stepMode, uint8_t stepSize, bool withOnOff)
+{
+    const int direction = stepMode == LevelControl::StepModeEnum::kUp ? 1 : -1;
+    const int nextLevel = static_cast<int>(entry->level) + (direction * static_cast<int>(stepSize));
+    ApplyMatterKioskCommandLevel(handlerContext, entry, ClampMatterKioskLevel(nextLevel), withOnOff);
+}
+
+void MatterKioskLevelControlCommandHandler::InvokeCommand(HandlerContext & handlerContext)
+{
+    MatterKioskBridgeDevice * entry = FindMatterKioskDeviceByEndpointId(handlerContext.mRequestPath.mEndpointId);
+    if (entry == nullptr || !entry->dimmable)
+    {
+        handlerContext.SetCommandNotHandled();
+        return;
+    }
+
+    switch (handlerContext.mRequestPath.mCommandId)
+    {
+    case LevelControl::Commands::MoveToLevel::Id:
+        HandleCommand<LevelControl::Commands::MoveToLevel::DecodableType>(handlerContext,
+                                                                          [entry](HandlerContext & context, const auto & request) {
+                                                                              ApplyMatterKioskCommandLevel(context, entry, request.level, false);
+                                                                          });
+        return;
+    case LevelControl::Commands::MoveToLevelWithOnOff::Id:
+        HandleCommand<LevelControl::Commands::MoveToLevelWithOnOff::DecodableType>(
+            handlerContext, [entry](HandlerContext & context, const auto & request) {
+                ApplyMatterKioskCommandLevel(context, entry, request.level, true);
+            });
+        return;
+    case LevelControl::Commands::Step::Id:
+        HandleCommand<LevelControl::Commands::Step::DecodableType>(handlerContext,
+                                                                   [entry](HandlerContext & context, const auto & request) {
+                                                                       ApplyMatterKioskStep(context, entry, request.stepMode, request.stepSize, false);
+                                                                   });
+        return;
+    case LevelControl::Commands::StepWithOnOff::Id:
+        HandleCommand<LevelControl::Commands::StepWithOnOff::DecodableType>(
+            handlerContext, [entry](HandlerContext & context, const auto & request) {
+                ApplyMatterKioskStep(context, entry, request.stepMode, request.stepSize, true);
+            });
+        return;
+    default:
+        handlerContext.SetCommandNotHandled();
+        return;
+    }
+}
