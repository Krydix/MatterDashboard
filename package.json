{
  "name": "matter-kiosk",
  "version": "0.1.0",
  "description": "Matter bridge kiosk app — displays configured webpages on Matter on/off commands",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite build --watch --mode development",
    "dev:electron": "wait-on dist/renderer/index.html && tsc -p tsconfig.main.json --watch & wait-on dist/main/index.js && electron .",
    "build": "npm run build:native && npm run build:renderer && npm run build:main",
    "build:native": "node ./scripts/build-native.mjs",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "keywords": [
    "matter",
    "kiosk",
    "electron",
    "smart-home"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@matter/main": "^0.16.11",
    "@matter/nodejs": "^0.16.11",
    "electron-liquid-glass": "^1.1.1",
    "electron-store": "^8.2.0",
    "fast-xml-parser": "^5.7.3",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "liquidjs": "^10.25.7",
    "qrcode.react": "^4.2.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.matterkiosk.app",
    "productName": "MatterKiosk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!assets/bin/**/*",
      "!assets/native/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/bin",
        "to": "bin"
      },
      {
        "from": "assets/native",
        "to": "native"
      }
    ],
    "asarUnpack": [
      "node_modules/@matter/**",
      "node_modules/@noble/**",
      "node_modules/@sindresorhus/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
